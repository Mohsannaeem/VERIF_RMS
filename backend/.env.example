# Copy this file to .env and fill in your values.
# The backend reads these at startup via os.getenv().

# CORS: origin of the frontend (no trailing slash)
CORS_ORIGIN=http://localhost:5173

# Database URL (SQLite default; swap for postgresql://... in production)
DATABASE_URL=sqlite:///rms.db

# API Key for write endpoints (POST/PATCH/DELETE).
# Leave empty to disable auth entirely (development only).
RMS_API_KEY=
